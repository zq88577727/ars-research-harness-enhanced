{
  "id": "gbd-analysis-template",
  "description": "Copy this file into a GBD project and fill every dimension exactly as exported before generating results.",
  "analyses": {
    "primary": {
      "sourceFile": "examples/<project>/source_exports/<approved-gbd-export>.csv",
      "outputCsv": "examples/<project>/results/gbd_primary_summary.csv",
      "outputMarkdown": "examples/<project>/results/gbd_primary_summary.md",
      "dimensionFilter": {
        "gbd_release": "GBD 2023",
        "version_id": "<version id if available>",
        "cause": "<cause>",
        "location": "<location>",
        "age": "<age group>",
        "sex": "<sex>"
      },
      "numberYear": "<comparison year>",
      "rateBaselineYear": "<baseline year>",
      "rateComparisonYear": "<comparison year>",
      "numberMeasures": {
        "deaths": {
          "measure": "Deaths",
          "metric": "Number"
        },
        "dalys": {
          "measure": "DALYs",
          "metric": "Number"
        }
      },
      "rateMeasure": {
        "measure": "Deaths",
        "metric": "Rate"
      },
      "interpretationBoundary": "Document query dimensions, uncertainty intervals, metric scale, citation, and reuse terms before manuscript use."
    }
  }
}
